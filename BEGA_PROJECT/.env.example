# .env.example 파일 (Git에 포함되어야 함)
# 이 파일은 프로젝트 구동에 필요한 환경 변수 키 목록을 보여줍니다.


# --- Security ---
JWT_SECRET=your-32-character-or-longer-secret-key
OAUTH2_COOKIE_SECRET=your-oauth2-cookie-signing-secret

# --- Database (Oracle) ---
SPRING_DATASOURCE_URL=jdbc:oracle:thin:@your-oracle-host:1521/yourdb
SPRING_DATASOURCE_USERNAME=your_oracle_username
SPRING_DATASOURCE_PASSWORD=your_oracle_password
# When using a TNS alias (like your-oracle-alias), set ORACLE_TNS_ADMIN and provide wallet files.
ORACLE_TNS_ADMIN=/app/wallet
ORACLE_WALLET_HOST_PATH=./wallet

# (Dev profile primary datasource — PostgreSQL)
# targetServerType=primary 를 URL에 포함하면 standby 연결을 드라이버 수준에서 즉시 차단
DB_URL=jdbc:postgresql://your-dev-pg-host:5432/your_db
DB_USERNAME=your_dev_db_username
DB_PASSWORD=your_dev_db_password

# (Baseball / Stadium secondary datasource — dev & prod 공통)
# dev에서는 DB_URL로 fallback 되지만, OCI PostgreSQL 접근 시 명시적으로 설정 권장
BASEBALL_DB_URL=jdbc:postgresql://your-baseball-pg-host:5432/your_baseball_db
BASEBALL_DB_USERNAME=your_baseball_db_username
BASEBALL_DB_PASSWORD=your_baseball_db_password

# --- Mail (compatibility with docker-compose) ---
# Local/dev defaults to disabled mail delivery unless explicitly enabled.
APP_MAIL_ENABLED=false
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_smtp_password
SPRING_MAIL_USERNAME=your_email@example.com
SPRING_MAIL_PASSWORD=your_smtp_password

# --- (Optional) Spring profile ---
SPRING_PROFILES_ACTIVE=local

# --- OCI Object Storage (S3 compatible) ---
OCI_S3_ACCESS_KEY=your_access_key
OCI_S3_SECRET_KEY=your_secret_key
OCI_S3_ENDPOINT=https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
OCI_S3_REGION=ap-seoul-1
OCI_S3_BUCKET=your_bucket

# --- Frontend ---
FRONTEND_URL=http://localhost:3000

# --- AI Service ---
AI_SERVICE_URL=http://localhost:8001
# Local dev fallback token. Override with a strong random token outside local-only environments.
AI_INTERNAL_TOKEN=local-dev-ai-internal-token

# --- Mate Payment/Payout ---
# Keep dark launch default on stage/prod until payout smoke is done.
MATE_PAYMENT_MODE=DIRECT_TRADE
MATE_REQUIRE_SOCIAL_VERIFICATION=true
PAYMENT_SELLING_ENFORCED=true
PAYMENT_PAYOUT_ENABLED=false
PAYMENT_PAYOUT_PROVIDER=SIM
MATE_FEE_RATE=0.10
TOSS_PAYMENT_SECRET_KEY=test_sk_your_toss_test_secret_key

# --- Toss Payout (required when PAYMENT_PAYOUT_PROVIDER=TOSS) ---
TOSS_PAYOUT_API_SECRET=your_toss_payout_api_secret
TOSS_PAYOUT_BASE_URL=https://api.tosspayments.com
TOSS_PAYOUT_SECURITY_MODE=ENCRYPTION
TOSS_PAYOUT_ENCRYPTION_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----...-----END PUBLIC KEY-----
# or use file path instead of direct key value
TOSS_PAYOUT_ENCRYPTION_PUBLIC_KEY_PATH=/secure/path/to/toss-payout-public-key.pem

# Google OAuth2 인증 정보
# TODO: Google Cloud Console에서 발급받은 실제 Client ID를 입력하세요.
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# Kakao OAuth2 인증 정보
KAKAO_CLIENT_ID=YOUR_KAKAO_CLIENT_ID
KAKAO_CLIENT_SECRET=YOUR_KAKAO_CLIENT_SECRET

# Naver OAuth2 인증 정보
NAVER_CLIENT_ID=YOUR_NAVER_CLIENT_ID
NAVER_CLIENT_SECRET=YOUR_NAVER_CLIENT_SECRET

# --- App URLs ---
APP_FRONTEND_URL=http://localhost:3000
APP_BACKEND_URL=http://localhost:8080
APP_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5176,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:5173,https://www.begabaseball.xyz,https://begabaseball.xyz,https://*.frontend-dfl.pages.dev
NAVER_REDIRECT_URI=http://localhost:8080/login/oauth2/code/naver

# # H2 데이터베이스 정보
# DB_URL=jdbc:h2:~/local
# DB_USERNAME=sa
# DB_PASSWORD=
